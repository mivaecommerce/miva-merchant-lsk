	<MvEVAL EXPR = "{ [ g.Module_Library_DB ].SQL_Query_LEFT_OUTER_JOIN( l.query, 'o', g.Store_Table_Prefix $ 'PriceGroupXBusinessAccount', 'pgxba', 'pgxba.pgrp_id = ? AND pgxba.account_id = c.account_id', [ g.Module_Library_DB ].SQL_Query_Field( l.query:pricegroup_id ) ) }">
