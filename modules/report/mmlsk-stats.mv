<MvFUNCTION NAME = "Module_Description" PARAMETERS = "module var" STANDARDOUTPUTLEVEL = "">
	<MvASSIGN NAME = "l.module:code"		VALUE = "mmlsk-report_stats">
	<MvASSIGN NAME = "l.module:name"		VALUE = "Statistics Display">
	<MvASSIGN NAME = "l.module:provider"	VALUE = "Miva Merchant">
	<MvASSIGN NAME = "l.module:version"		VALUE = "26.0100">
	<MvASSIGN NAME = "l.module:api_ver"		VALUE = "26.01">
	<MvASSIGN NAME = "l.module:features"	VALUE = "report">
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Capabilities" PARAMETERS = "module var, capabilities var" STANDARDOUTPUTLEVEL = "">
	<MvASSIGN NAME = "l.capabilities:date_range"		VALUE = 0>
	<MvASSIGN NAME = "l.capabilities:date_interval"		VALUE = 0>
	<MvASSIGN NAME = "l.capabilities:display"			VALUE = 1>
	<MvASSIGN NAME = "l.capabilities:output_chart"		VALUE = 0>
	<MvASSIGN NAME = "l.capabilities:output_tabular"	VALUE = 0>
	<MvASSIGN NAME = "l.capabilities:output_custom"		VALUE = 0>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Property_Template" PARAMETERS = "module var" STANDARDOUTPUTLEVEL = "text, html, compresswhitespace">
	<mm-grid columns="3" column-sizes="repeat( 3, 1fr )">
		<mm-grid-row>
			<mm-grid-column>
				<mm-module-field-ui code="display" size="full"></mm-module-field-ui>
			</mm-grid-column>
		</mm-grid-row>
	</mm-grid>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Properties" PARAMETERS = "module var" STANDARDOUTPUTLEVEL = "text, html, compresswhitespace">
	{
		"display":
		{
			"type": "select",
			"prompt": "Display",
			"required": true,
			"options":
			[
				{
					"text": "Statistics",
					"value": "statistics"
				},
				{
					"text": "Best Sellers",
					"value": "bestsellers"
				}
			]
		}
	}
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Settings_Default" PARAMETERS = "module var, settings var" STANDARDOUTPUTLEVEL = "">
	<MvASSIGN NAME = "l.settings:display:value" VALUE = "statistics">

	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Settings_Load" PARAMETERS = "module var, report var, settings var" STANDARDOUTPUTLEVEL = "">
	<MvASSIGN NAME = "l.settings"				VALUE = "">
	<MvASSIGN NAME = "l.settings:display:value"	VALUE = "{ l.report:config:display }">

	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Settings_Validate" PARAMETERS = "module var, settings var" STANDARDOUTPUTLEVEL = "">
	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Settings_Update" PARAMETERS = "module var, report var, settings var" STANDARDOUTPUTLEVEL = "">
	<MvASSIGN NAME = "l.report:config:display" VALUE = "{ l.settings:display:value }">

	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Delete" PARAMETERS = "module var, report var" STANDARDOUTPUTLEVEL = "">
	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Run" PARAMETERS = "module var, report var" STANDARDOUTPUTLEVEL = "">
	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "ReportModule_Display" PARAMETERS = "module var, report var" STANDARDOUTPUTLEVEL = "">
	<MvIF EXPR = "{ l.report:config:display EQ 'statistics' }">			<MvFUNCTIONRETURN VALUE = "{ Stats_Display_Statistics() }">
	<MvELSEIF EXPR = "{ l.report:config:display EQ 'bestsellers' }">	<MvFUNCTIONRETURN VALUE = "{ Stats_Display_BestSellers() }">
	</MvIF>

	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "Stats_Display_Statistics" STANDARDOUTPUTLEVEL = "text, html, compresswhitespace">
	<MvIF EXPR = "{ NOT [ g.Module_Feature_STA_DB ].Stats_Load( l.stats ) }">
		<MvFUNCTIONRETURN VALUE = 0>
	</MvIF>

	<style type="text/css" data-report-dependency-id="report-display-stats">
		.mm_report_stats_home_screen_entry
		{
			padding: var(--mm-report-stats-home-screen-row-padding);
			align-items: center;
			border: var(--mm-report-stats-home-screen-row-border);
			border-radius: var(--mm-report-stats-home-screen-row-border-radius);
		}
	</style>

	<mm-grid columns="2" column-sizes="1fr 1fr" row-gap="8px" mm-size-to-fit>
		<mm-grid-column grid-column="span 2" class="mm_report_stats_home_screen_entry">
			<mm-flex-item>
				<mm-text type="paragraph-small" size="full" tone="600" spacing-bottom="6px">Revenue</mm-text>
				<mm-text type="display-6" size="full" tone="900"><MvEVAL EXPR = "{ [ g.Module_Root $ g.Store:currncy_mod:module ].CurrencyModule_AddFormatting( g.Store:currncy_mod, l.stats:revenue ROUND 2 ) }"></mm-text>
			</mm-flex-item>
		</mm-grid-column>

		<mm-grid-column class="mm_report_stats_home_screen_entry">
			<mm-flex-item>
				<mm-text type="paragraph-small" size="full" tone="600" spacing-bottom="6px">Orders</mm-text>
				<mm-text type="display-6" size="full" tone="900"><MvEVAL EXPR = "{ [ g.Module_Library_Utilities ].Format_Number( l.stats:orders ) }"></mm-text>
			</mm-flex-item>
		</mm-grid-column>

		<mm-grid-column class="mm_report_stats_home_screen_entry">
			<mm-flex-item>
				<mm-text type="paragraph-small" size="full" tone="600" spacing-bottom="6px">Products Sold</mm-text>
				<mm-text type="display-6" size="full" tone="900"><MvEVAL EXPR = "{ [ g.Module_Library_Utilities ].Format_Number( l.stats:products ) }"></mm-text>
			</mm-flex-item>
		</mm-grid-column>

		<MvIF EXPR = "{ g.Store:trackhits }">
			<mm-grid-column class="mm_report_stats_home_screen_entry">
				<mm-flex-item>
					<mm-text type="paragraph-small" size="full" tone="600" spacing-bottom="6px">Hits</mm-text>
					<mm-text type="display-6" size="full" tone="900"><MvEVAL EXPR = "{ [ g.Module_Library_Utilities ].Format_Number( l.stats:hits ) }"></mm-text>
				</mm-flex-item>
			</mm-grid-column>

			<mm-grid-column class="mm_report_stats_home_screen_entry">
				<mm-flex-item>
					<mm-text type="paragraph-small" size="full" tone="600" spacing-bottom="6px">Visits</mm-text>
					<mm-text type="display-6" size="full" tone="900"><MvEVAL EXPR = "{ [ g.Module_Library_Utilities ].Format_Number( l.stats:visits ) }"></mm-text>
				</mm-flex-item>
			</mm-grid-column>
		</MvIF>
	</mm-grid>

	<MvIF EXPR = "{ g.Admin_User_Administrator }">
		<mm-button button-style="link" size="auto small" data-report-footer-action onclick="{ 'JavaScript:PopupStatReset( \'' $ [ g.Module_Admin ].JavaScriptEncode( g.Store:code ) $ '\' );' }">Reset</mm-button>
		<mm-text type="paragraph-small" tone="500" data-report-footer-custom>Last Reset on: <MvEVAL EXPR = "{ padl( time_t_month( l.stats:resetdate, g.Merchant_Local_Timezone ), 2, '0' ) }">/<MvEVAL EXPR = "{ padl( time_t_dayofmonth( l.stats:resetdate, g.Merchant_Local_Timezone ), 2, '0' ) }">/<MvEVAL EXPR = "{ padl( time_t_year( l.stats:resetdate, g.Merchant_Local_Timezone ), 2, '0' ) }"></mm-text>
	</MvIF>

	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>

<MvFUNCTION NAME = "Stats_Display_BestSellers" STANDARDOUTPUTLEVEL = "text, html, compresswhitespace">
	<MvASSIGN NAME = "l.bestseller_pos"		VALUE = 1>
	<MvASSIGN NAME = "l.bestseller_count"	VALUE = "{ [ g.Module_Feature_STA_DB ].ProdStatsList_Load_Max( 5, l.prodstats ) }">

	<MvIF EXPR = "{ l.bestseller_count EQ 0 }">
		<MvEVAL EXPR = "{ [ g.Module_Feature_RPT_UT ].ReportData_Render_Unavailable() }">
		<MvFUNCTIONRETURN VALUE = 1>
	</MvIF>

	<mm-grid columns="2" column-sizes="1fr auto" row-gap="0px" mm-size-to-fit>
		<mm-grid-row data-report-content-header-row>
			<mm-grid-column align-items="center">
				<mm-text type="paragraph-small" tone="900" weight="600">
					Product
				</mm-text>
			</mm-grid-column>

			<mm-grid-column align-items="center" justify-content="end">
				<mm-text type="paragraph-small" tone="900" weight="600">
					Total Units Sold
				</mm-text>
			</mm-grid-column>
		</mm-grid-row>

		<MvASSIGN NAME = "l.customer_pos" VALUE = 1>
		<MvWHILE EXPR = "{ l.bestseller_pos LE l.bestseller_count }">
			<mm-grid-row data-report-content-data-row>
				<mm-grid-column align-items="center">
					<mm-text type="paragraph-medium" tone="600" nowrap>
						<MvEVAL EXPR = "{ encodeentities( l.prodstats[ l.bestseller_pos ]:prod_name ) }">
					</mm-text>
				</mm-grid-column>

				<mm-grid-column align-items="center" justify-content="end">
					<mm-text type="paragraph-medium" tone="600" weight="500">
						<MvEVAL EXPR = "{ [ g.Module_Library_Utilities ].Format_Number( l.prodstats[ l.bestseller_pos ]:counter ) }">
					</mm-text>
				</mm-grid-column>
			</mm-grid-row>

			<MvASSIGN NAME = "l.bestseller_pos"	VALUE = "{ l.bestseller_pos + 1 }">
		</MvWHILE>
	</mm-grid>
	
	<MvFUNCTIONRETURN VALUE = 1>
</MvFUNCTION>
