								s.cncldate		>= ?			AND
								s.cncldate		<= ?
							  GROUP BY
								s.product_id' }"
				FIELDS	= "l.start, l.query:time_t_end">
	<MvIF EXPR = "{ g.MvOPENVIEW_Error }">
